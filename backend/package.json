{
  "name": "bandcheck-backend",
  "version": "1.0.0",
  "description": "BandCheck API server",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "build": "echo 'No build step needed for Bun'",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "docker:build": "docker build -t bandcheck-backend .",
    "docker:run": "docker run -p 3000:3000 --env-file .env bandcheck-backend",
    "test": "echo \"No tests yet...\""
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@libsql/client": "^0.17.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.10",
    "@types/jsonwebtoken": "^9.0.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
